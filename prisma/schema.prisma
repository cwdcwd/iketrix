generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  clerkId         String    @unique
  email           String    @unique
  name            String?
  githubToken     String?   // GitHub App OAuth user access token
  githubRefreshToken String? // GitHub App refresh token for token renewal
  githubTokenExpiresAt DateTime? // When the access token expires
  githubInstallationId String? // GitHub App installation ID
  classifierModel String?   // e.g. "gpt-4o-mini", "gpt-4o", "claude-sonnet-4-20250514"
  classifierPrompt String?  // Custom system prompt override for classification
  agentModel      String?   // Model used for delegation agent conversations
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  matrices        Matrix[]
  tasks           Task[]
  sources         Source[]
  overrides       ClassificationOverride[]
  memories        ClassifierMemory[]
  contacts        Contact[] @relation("ContactOwner")
  linkedContacts  Contact[] @relation("ContactLinkedUser")
  agentConversations AgentConversation[]
}

model Matrix {
  id              String    @id @default(cuid())
  name            String
  description     String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         Source[]
  tasks           Task[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Source {
  id              String    @id @default(cuid())
  type            String    // "github", "jira", "linear", etc.
  name            String    // e.g., "owner/repo"
  accessToken     String    // encrypted OAuth token
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matrixId        String?
  matrix          Matrix?   @relation(fields: [matrixId], references: [id], onDelete: SetNull)
  tasks           Task[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, type, name])
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  sourceId        String?
  source          Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  externalId      String?   // GitHub issue number, etc.
  externalUrl     String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matrixId        String?
  matrix          Matrix?   @relation(fields: [matrixId], references: [id], onDelete: SetNull)
  quadrant        String?   // "do", "schedule", "delegate", "delete"
  status          String    @default("active") // "active", "delegated", "completed", "deleted"
  needsClarification Boolean @default(false)
  pendingQuestion    String?  // LLM's clarifying question
  classification  TaskClassification?
  clarifications  Clarification[]
  overrides       ClassificationOverride[]
  delegatedTo     String?   // email or identifier of delegatee
  delegatedAt     DateTime?
  delegatedToContactId String?
  delegatedToContact   Contact? @relation(fields: [delegatedToContactId], references: [id], onDelete: SetNull)
  agentConversation    AgentConversation?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sourceId, externalId])
}

model Clarification {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model TaskClassification {
  id              String    @id @default(cuid())
  taskId          String    @unique
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  quadrant        String    // "do", "schedule", "delegate", "delete"
  reasoning       String    // LLM explanation
  confidence      Float     // 0-1 score
  model           String    // which LLM model was used
  createdAt       DateTime  @default(now())
}

model ClassificationOverride {
  id              String    @id @default(cuid())
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromQuadrant    String
  toQuadrant      String
  createdAt       DateTime  @default(now())
}

model ClassifierMemory {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content         String    // Distilled lesson from user corrections
  sourceOverrideId String?  // The override that triggered this memory
  createdAt       DateTime  @default(now())
}

model Contact {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("ContactOwner", fields: [userId], references: [id], onDelete: Cascade)
  email           String
  name            String?
  linkedUserId    String?
  linkedUser      User?     @relation("ContactLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  clerkInvitationId String?
  inviteStatus    String?   // "pending" | "accepted"
  delegatedTasks  Task[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, email])
}

model AgentConversation {
  id              String    @id @default(cuid())
  taskId          String    @unique
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String    @default("active") // "active" | "completed" | "abandoned"
  summary         String?
  messages        AgentMessage[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AgentMessage {
  id              String    @id @default(cuid())
  conversationId  String
  conversation    AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String    // "user" | "assistant" | "tool"
  content         String
  toolName        String?
  toolArgs        Json?
  toolResult      Json?
  createdAt       DateTime  @default(now())
}
